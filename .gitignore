# Raw dataset (do not track)
# Ignore everything in raw
raw/*

# But allow metadata files
!raw/**/metadata.yaml

# (optional) keep folder structure
!raw/.gitkeep

*.mcap
*.db3
*.bag
outputs/tmp/

# macOS system files
.DS_Store
**/.DS_Store

# Python virtual environment
.venv/
.env

# Python cache
__pycache__/
*.pyc

# ROS build artifacts
build/
install/
log/